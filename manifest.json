{
  "manifest_version": 3,
  "name": "ARÜ Duyuru ve Menü",
  "version": "1.0.0",
  "description": "Ardahan Üniversitesi (ARÜ) güncel duyurularını ve yemek menüsünü takip eder.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Ardahan Üniversitesi"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "*://*.ardahan.edu.tr/*"
  ]
}